---
import BaseLayout from "@layouts/BaseLayout.astro";
import mainNav from "@data/mainNav.json";
import MainNav from "@components/navigation/main-nav/MainNav.astro";
---

<BaseLayout title="404 — Page Not Found">
  <MainNav
    logoSource={mainNav.logoSource}
    logoAlt={mainNav.logoAlt}
    navData={mainNav.navData}
    buttonSections={mainNav.buttonSections}
  />

  <section class="error-page">
    <div class="error-page__bg" aria-hidden="true">
      <div class="error-page__orb error-page__orb--1"></div>
      <div class="error-page__orb error-page__orb--2"></div>
      <div class="error-page__grid"></div>
    </div>

    <div class="error-page__content">
      <span class="error-page__code">404</span>
      <div class="error-page__glitch" aria-hidden="true">404</div>
      <h1 class="error-page__heading">Signal lost</h1>
      <p class="error-page__text">The page you're looking for doesn't exist or has been moved.</p>
      <div class="error-page__actions">
        <a href="/" class="error-page__btn error-page__btn--primary">Back to Home</a>
        <button class="error-page__btn error-page__btn--secondary" data-cmd-trigger type="button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
          Search
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .error-page {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 60px);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
  }

  /* Background effects */
  .error-page__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .error-page__orb--1 {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(255, 107, 107, 0.12) 0%, transparent 70%);
    top: 10%;
    left: 20%;
    filter: blur(80px);
    animation: error-orb-1 12s ease-in-out infinite;
  }

  .error-page__orb--2 {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 229, 255, 0.08) 0%, transparent 70%);
    bottom: 10%;
    right: 20%;
    filter: blur(80px);
    animation: error-orb-2 16s ease-in-out infinite;
  }

  .error-page__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(0, 229, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 229, 255, 0.02) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(circle at center, rgba(0,0,0,0.3), transparent 70%);
    -webkit-mask-image: radial-gradient(circle at center, rgba(0,0,0,0.3), transparent 70%);
  }

  @keyframes error-orb-1 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(30px, -20px); }
  }

  @keyframes error-orb-2 {
    0%, 100% { transform: translate(0, 0); }
    50% { transform: translate(-20px, 15px); }
  }

  /* Content */
  .error-page__content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-xl);
  }

  .error-page__code {
    display: block;
    font-family: var(--font-headings);
    font-size: clamp(8rem, 20vw, 16rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 0.85;
    background: linear-gradient(180deg, var(--color-text-strong) 0%, rgba(0, 229, 255, 0.15) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    position: relative;
    user-select: none;
  }

  /* Glitch effect */
  .error-page__glitch {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-headings);
    font-size: clamp(8rem, 20vw, 16rem);
    font-weight: 700;
    letter-spacing: -0.06em;
    line-height: 0.85;
    color: var(--brand-cyan);
    opacity: 0;
    animation: glitch 4s ease-in-out infinite;
    pointer-events: none;
    user-select: none;
  }

  @keyframes glitch {
    0%, 90%, 100% { opacity: 0; transform: translateX(-50%); }
    92% { opacity: 0.4; transform: translateX(calc(-50% + 8px)); clip-path: inset(20% 0 40% 0); }
    94% { opacity: 0; }
    96% { opacity: 0.3; transform: translateX(calc(-50% - 6px)); clip-path: inset(60% 0 10% 0); }
    98% { opacity: 0; }
  }

  .error-page__heading {
    font-family: var(--font-headings);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--color-text-strong);
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
  }

  .error-page__text {
    font-size: var(--font-size-lg);
    color: var(--color-text-subtle);
    max-width: 400px;
    margin-inline: auto;
    line-height: 1.6;
  }

  .error-page__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-md);
    margin-top: var(--spacing-xl);
    flex-wrap: wrap;
  }

  .error-page__btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 10px;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.3s ease;
  }

  .error-page__btn:hover {
    transform: translateY(-2px);
  }

  .error-page__btn--primary {
    background: linear-gradient(135deg, var(--brand-cyan) 0%, #00b8d4 100%);
    color: var(--brand-black);
    border: none;
    box-shadow: 0 0 20px rgba(0, 229, 255, 0.15), 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .error-page__btn--primary:hover {
    box-shadow: 0 0 30px rgba(0, 229, 255, 0.3), 0 8px 24px rgba(0, 0, 0, 0.25);
  }

  .error-page__btn--secondary {
    background: transparent;
    color: var(--color-text-subtle);
    border: 1px solid var(--color-border);
  }

  .error-page__btn--secondary:hover {
    border-color: var(--brand-cyan);
    color: var(--brand-cyan);
  }

  /* Light theme overrides */
  [data-theme="light"] .error-page__orb--1 {
    background: radial-gradient(circle, rgba(255, 107, 107, 0.06) 0%, transparent 70%);
  }

  [data-theme="light"] .error-page__orb--2 {
    background: radial-gradient(circle, rgba(0, 184, 212, 0.05) 0%, transparent 70%);
  }

  [data-theme="light"] .error-page__grid {
    background:
      linear-gradient(rgba(0, 0, 0, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.02) 1px, transparent 1px);
  }

  [data-theme="light"] .error-page__glitch {
    color: var(--brand-coral);
  }

  [data-theme="light"] .error-page__btn--primary {
    box-shadow: 0 2px 12px rgba(0, 184, 212, 0.25);
  }
</style>
