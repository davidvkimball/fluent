---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Bar from "@components/navigation/bar/Bar.astro";
import Mobile from "@components/navigation/mobile/Mobile.astro";
import Image from "@core-elements/image/Image.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

type NavButton = {
  text?: string;
  href?: string;
  [key: string]: unknown;
};

const {
  logoSource,
  logoAlt = "logo",
  navData = [],
  buttonSections = [] as NavButton[],
  class: className,
  useDefaultEditableBinding: _useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const mobileNavData = [
  ...navData,
  ...buttonSections.map((button: NavButton) => ({
    name: button.text || "Button",
    path: button.href || "#",
    children: [],
  })),
];
---

<CustomSection
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical="none"
  class:list={["main-nav", className]}
  {...htmlAttributes}
  useDefaultEditableBinding={false}
>
  <a href="/">
    <Image
      source={logoSource}
      class="main-nav-logo"
      alt={logoAlt}
      useDefaultEditableBinding={false}
    />
  </a>
  <div class="nav-end">
    <Bar
      navData={navData}
      class="desktop-main-nav"
    />

    <button id="command-palette-trigger" class="nav-search-trigger" aria-label="Search (Ctrl+K)" type="button">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/></svg>
      <kbd>⌘K</kbd>
    </button>

    <ButtonGroup
      direction="row"
      align="center"
      class="desktop-button-group"
      buttonSections={buttonSections}
      useDefaultEditableBinding={false}
    />
  </div>
  <Mobile
    logoSource={logoSource}
    logoAlt={logoAlt}
    navData={mobileNavData}
    class="mobile-main-nav"
    useDefaultEditableBinding={false}
  />
</CustomSection>

<style is:global>
  @layer page-sections {
    .main-nav {
      background-color: color-mix(in srgb, var(--color-bg) 80%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border-subtle);
      padding-block: var(--spacing-md);
      position: sticky;
      top: 0;
      z-index: var(--layer-2);

      .desktop-main-nav,
      .desktop-button-group.button-group {
        @container (max-width: 768px) {
          display: none;
        }
      }

      .main-nav-logo {
        margin-top: 0 !important;
      }

      .nav-hamburger.mobile-button {
        @container (min-width: 769px) {
          display: none;
        }
      }

      > .outer-content > .content {
        align-items: center;
        container-type: inline-size;
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-md);

        > a > .image img {
          height: 1.8em;
          max-width: min(20em, 100%);
          width: auto;
        }

        .button-group {
          margin-top: 0;
        }
      }

      > .outer-content > .content > .nav-end {
        align-items: center;
        display: flex;
        flex-shrink: 0;
        justify-content: flex-end;
        margin-left: auto;

        > .button-group {
          container-type: normal;
        }
      }

      .nav-search-trigger {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 6px 12px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-sm);
        color: var(--color-text-muted);
        font-size: 0.8125rem;
        cursor: pointer;
        transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;

        &:hover {
          border-color: var(--brand-cyan);
          color: var(--brand-cyan);
          background: rgba(0, 229, 255, 0.04);
        }

        kbd {
          font-family: var(--font-body);
          font-size: 0.6875rem;
          padding: 1px 5px;
          border: 1px solid var(--color-border);
          border-radius: 3px;
          opacity: 0.6;
        }

        @container (max-width: 768px) {
          kbd { display: none; }
          padding: 6px 8px;
        }
      }
    }
  }
</style>
