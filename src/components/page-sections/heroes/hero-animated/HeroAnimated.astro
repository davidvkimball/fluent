---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  eyebrow = "",
  heading = "",
  subtext = "",
  rotatingWords = [],
  buttonSections = [],
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "6xl",
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const wordsJson = JSON.stringify(rotatingWords);
---

<CustomSection
  class:list={["hero-animated", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <!-- Animated background elements -->
  <div class="hero-animated__bg" aria-hidden="true">
    <div class="hero-animated__orb hero-animated__orb--1"></div>
    <div class="hero-animated__orb hero-animated__orb--2"></div>
    <div class="hero-animated__grid"></div>
    <div class="hero-animated__scanline"></div>
  </div>

  <div class="hero-animated__split">
    <div class="hero-animated__content">
      <SimpleText
        class="eyebrow"
        data-prop="eyebrow"
        text={eyebrow}
        alignX="start"
      />

      <h1 class="hero-animated__heading">
        <span class="hero-animated__heading-text" data-prop="heading">{heading}</span>
        {rotatingWords.length > 0 && (
          <span class="hero-animated__rotating-wrap">
            <span class="hero-animated__rotating" data-words={wordsJson}>
              {rotatingWords[0]}
            </span>
            <span class="hero-animated__cursor"></span>
          </span>
        )}
      </h1>

      <Text
        class="hero-animated__subtext"
        alignX="start"
        data-prop="subtext"
        text={subtext}
      />

      <ButtonGroup
        class="hero-animated__buttons"
        buttonSections={buttonSections}
        direction="row"
        alignX="start"
        data-children-prop="buttonSections"
      />
    </div>

    <!-- 3D Element -->
    <div class="hero-animated__visual" aria-hidden="true">
      <!-- Back ring halves (behind cube) -->
      <div class="hero-animated__ring-layer hero-animated__ring-layer--back">
        <div class="hero-animated__ring hero-animated__ring--1"></div>
        <div class="hero-animated__ring hero-animated__ring--2"></div>
        <div class="hero-animated__ring hero-animated__ring--3"></div>
      </div>
      <!-- Cube in its own flat stacking layer -->
      <div class="hero-animated__cube-wrap">
        <div class="hero-animated__cube" id="hero-cube">
          <div class="hero-animated__cube-face hero-animated__cube-face--front">
            <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--brand-cyan)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M16.247 7.761a6 6 0 0 1 0 8.478"/><path d="M19.075 4.933a10 10 0 0 1 0 14.134"/><path d="M4.925 19.067a10 10 0 0 1 0-14.134"/><path d="M7.753 16.239a6 6 0 0 1 0-8.478"/><circle cx="12" cy="12" r="2"/></svg>
          </div>
          <div class="hero-animated__cube-face hero-animated__cube-face--back"></div>
          <div class="hero-animated__cube-face hero-animated__cube-face--right"></div>
          <div class="hero-animated__cube-face hero-animated__cube-face--left"></div>
          <div class="hero-animated__cube-face hero-animated__cube-face--top"></div>
          <div class="hero-animated__cube-face hero-animated__cube-face--bottom"></div>
        </div>
      </div>
      <!-- Front ring halves (in front of cube) -->
      <div class="hero-animated__ring-layer hero-animated__ring-layer--front">
        <div class="hero-animated__ring hero-animated__ring--1"></div>
        <div class="hero-animated__ring hero-animated__ring--2"></div>
        <div class="hero-animated__ring hero-animated__ring--3"></div>
      </div>
      <div class="hero-animated__spark" aria-hidden="true"></div>
    </div>
  </div>
</CustomSection>

<script>
  import { onPageLoad } from "@component-utils/onPageLoad";

  function initHeroAnimated() {
    // Rotating words
    const els = document.querySelectorAll('.hero-animated__rotating');
    els.forEach((el) => {
      const htmlEl = el as HTMLElement;
      if (htmlEl.dataset.initialized) return;
      htmlEl.dataset.initialized = 'true';

      const words: string[] = JSON.parse(htmlEl.dataset.words || '[]');
      if (words.length < 2) return;

      let index = 0;

      setInterval(() => {
        htmlEl.classList.add('hero-animated__rotating--out');

        setTimeout(() => {
          index = (index + 1) % words.length;
          htmlEl.textContent = words[index];
          htmlEl.classList.remove('hero-animated__rotating--out');
          htmlEl.classList.add('hero-animated__rotating--in');

          setTimeout(() => {
            htmlEl.classList.remove('hero-animated__rotating--in');
          }, 400);
        }, 400);
      }, 3000);
    });

    // 3D cube: scroll + drag + sparks + glitch
    const cube = document.getElementById('hero-cube');
    const visual = cube?.closest('.hero-animated__visual') as HTMLElement | null;
    const spark = visual?.querySelector('.hero-animated__spark') as HTMLElement | null;
    if (cube && !cube.dataset.scrollInit) {
      cube.dataset.scrollInit = 'true';

      let baseX = -15;
      let baseY = 25;
      let dragX = 0;
      let dragY = 0;
      let velocityX = 0;
      let velocityY = 0;
      let isDragging = false;
      let startMouseX = 0;
      let startMouseY = 0;
      let startDragX = 0;
      let startDragY = 0;
      let lastMouseX = 0;
      let lastMouseY = 0;
      let lastMoveTime = 0;
      let animating = false;
      let sparkTimeout: number | null = null;

      // Keep angles in -180..180 range to prevent inverted controls
      function normalizeAngle(a: number): number {
        a = a % 360;
        if (a > 180) a -= 360;
        if (a < -180) a += 360;
        return a;
      }

      function emitSpark(speed: number) {
        if (!spark || !visual) return;
        if (speed < 1.5) return;
        const rect = visual.getBoundingClientRect();
        const cx = rect.width / 2;
        const cy = rect.height / 2;
        const angle = Math.random() * Math.PI * 2;
        const dist = 100 + Math.random() * 40;
        spark.style.left = `${cx + Math.cos(angle) * dist}px`;
        spark.style.top = `${cy + Math.sin(angle) * dist}px`;
        spark.style.opacity = `${Math.min(speed / 8, 0.8)}`;
        if (sparkTimeout) clearTimeout(sparkTimeout);
        sparkTimeout = window.setTimeout(() => {
          spark.style.opacity = '0';
        }, 80 + Math.random() * 60);
      }

      function updateCube() {
        const scrollY = window.scrollY;
        const scrollRX = scrollY * 0.03;
        const scrollRY = scrollY * 0.05;
        const rx = baseX + scrollRX + dragX;
        const ry = baseY + scrollRY + dragY;
        cube!.style.transform = `perspective(1800px) rotateX(${rx}deg) rotateY(${ry}deg)`;
      }

      function animateMomentum() {
        if (isDragging) { animating = false; return; }
        const speed = Math.sqrt(velocityX * velocityX + velocityY * velocityY);
        if (speed < 0.05) {
          animating = false;
          return;
        }
        dragX += velocityX;
        dragY += velocityY;
        dragX = normalizeAngle(dragX);
        dragY = normalizeAngle(dragY);
        velocityX *= 0.95;
        velocityY *= 0.95;

        // Cap velocity to prevent extreme spin
        const maxV = 8;
        velocityX = Math.max(-maxV, Math.min(maxV, velocityX));
        velocityY = Math.max(-maxV, Math.min(maxV, velocityY));

        if (Math.random() < 0.3) emitSpark(speed);
        updateCube();
        requestAnimationFrame(animateMomentum);
      }

      window.addEventListener('scroll', updateCube, { passive: true });

      const target = visual || cube;
      target.style.cursor = 'grab';

      target.addEventListener('pointerdown', (e: PointerEvent) => {
        isDragging = true;
        velocityX = 0;
        velocityY = 0;
        startMouseX = e.clientX;
        startMouseY = e.clientY;
        lastMouseX = e.clientX;
        lastMouseY = e.clientY;
        lastMoveTime = Date.now();
        startDragX = dragX;
        startDragY = dragY;
        target.style.cursor = 'grabbing';
        target.setPointerCapture(e.pointerId);
        e.preventDefault();
      });

      window.addEventListener('pointermove', (e: PointerEvent) => {
        if (!isDragging) return;
        const dx = e.clientX - startMouseX;
        const dy = e.clientY - startMouseY;
        dragY = normalizeAngle(startDragY + dx * 0.3);
        dragX = normalizeAngle(startDragX - dy * 0.3);

        const now = Date.now();
        const dt = Math.max(now - lastMoveTime, 1);
        velocityY = (e.clientX - lastMouseX) / dt * 8;
        velocityX = -(e.clientY - lastMouseY) / dt * 8;

        // Cap velocity during drag too
        const maxV = 8;
        velocityX = Math.max(-maxV, Math.min(maxV, velocityX));
        velocityY = Math.max(-maxV, Math.min(maxV, velocityY));

        const speed = Math.sqrt(velocityX * velocityX + velocityY * velocityY);
        if (Math.random() < 0.4) emitSpark(speed);

        lastMouseX = e.clientX;
        lastMouseY = e.clientY;
        lastMoveTime = now;

        updateCube();
      });

      window.addEventListener('pointerup', () => {
        if (!isDragging) return;
        isDragging = false;
        target.style.cursor = 'grab';
        if (!animating) {
          animating = true;
          requestAnimationFrame(animateMomentum);
        }
      });

      updateCube();
    }
  }

  onPageLoad(initHeroAnimated);
</script>

<style>
  @layer page-sections {
    :global(.hero-animated) {
      position: relative;
      overflow: hidden;
      min-height: 80vh;
      display: flex;
      align-items: center;
    }

    :global(.hero-animated) > :global(.outer-content) {
      position: relative;
      z-index: 2;
      width: 100%;
    }

    /* === BACKGROUND EFFECTS === */
    .hero-animated__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .hero-animated__orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
    }

    .hero-animated__orb--1 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(0, 229, 255, 0.2), transparent 70%);
      top: -10%;
      left: -5%;
      animation: orb-float-1 16s ease-in-out infinite;
    }

    .hero-animated__orb--2 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(255, 107, 107, 0.15), transparent 70%);
      bottom: -15%;
      right: -5%;
      animation: orb-float-2 20s ease-in-out infinite;
    }

    .hero-animated__grid {
      position: absolute;
      bottom: 0;
      left: -20%;
      right: -20%;
      height: 50%;
      background:
        linear-gradient(rgba(0, 229, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 229, 255, 0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      transform: perspective(500px) rotateX(60deg);
      transform-origin: center bottom;
      mask-image: linear-gradient(to top, rgba(0,0,0,0.4), transparent 80%);
      -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.4), transparent 80%);
    }

    .hero-animated__scanline {
      position: absolute;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent 10%, rgba(0, 229, 255, 0.3) 50%, transparent 90%);
      animation: scanline-sweep 5s linear infinite;
    }

    @keyframes scanline-sweep {
      0% { top: 0; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }

    @keyframes orb-float-1 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(40px, 30px); }
      66% { transform: translate(-20px, -15px); }
    }

    @keyframes orb-float-2 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(-30px, -25px); }
      66% { transform: translate(25px, 20px); }
    }

    /* === SPLIT LAYOUT === */
    .hero-animated__split {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: var(--spacing-2xl);
    }

    @media (max-width: 768px) {
      .hero-animated__split {
        grid-template-columns: 1fr;
      }

      .hero-animated__visual {
        display: none;
      }
    }

    /* === CONTENT (left) === */
    .hero-animated__content {
      position: relative;
      z-index: 2;
    }

    .hero-animated__heading {
      font-family: var(--font-headings);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1.1;
      color: var(--color-text-strong);
      margin-top: var(--spacing-lg);
      margin-bottom: var(--spacing-lg);
    }

    .hero-animated__heading-text {
      display: block;
    }

    .hero-animated__rotating-wrap {
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    .hero-animated__rotating {
      display: inline-block;
      color: var(--brand-cyan);
      transition: opacity 0.4s ease, transform 0.4s ease;
      min-width: 3ch;
    }

    .hero-animated__rotating--out {
      opacity: 0;
      transform: translateY(-12px);
    }

    .hero-animated__rotating--in {
      animation: word-in 0.4s ease forwards;
    }

    @keyframes word-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-animated__cursor {
      display: inline-block;
      width: 3px;
      height: 1em;
      background: var(--brand-cyan);
      margin-left: 2px;
      animation: blink 1s steps(1) infinite;
      vertical-align: text-bottom;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    :global(.hero-animated__subtext) {
      max-width: 480px;
      font-size: var(--font-size-lg);
    }

    :global(.hero-animated__buttons) {
      margin-top: var(--spacing-xl);
    }

    /* === 3D VISUAL (right) === */
    .hero-animated__visual {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      height: 500px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Ring layers — split for depth illusion */
    .hero-animated__ring-layer {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-animated__ring-layer--back {
      z-index: 1;
      clip-path: polygon(0 0, 100% 0, 100% 50%, 0 50%);
    }

    .hero-animated__ring-layer--front {
      z-index: 3;
      clip-path: polygon(0 50%, 100% 50%, 100% 100%, 0 100%);
    }

    /* Cube wrapper — sits between ring layers */
    .hero-animated__cube-wrap {
      position: relative;
      z-index: 2;
      perspective: none;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Cube */
    .hero-animated__cube {
      width: 240px;
      height: 240px;
      position: relative;
      transform-style: preserve-3d;
      transform: perspective(1800px) rotateX(-15deg) rotateY(25deg);
      will-change: transform;
    }

    .hero-animated__cube-face {
      position: absolute;
      width: 240px;
      height: 240px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1.5px solid rgba(0, 229, 255, 0.18);
      background: rgba(0, 229, 255, 0.02);
      backdrop-filter: blur(4px);
      -webkit-backdrop-filter: blur(4px);
      box-shadow: inset 0 0 30px rgba(0, 229, 255, 0.03);
    }

    .hero-animated__cube-face--front  { transform: translateZ(120px); border-color: rgba(0, 229, 255, 0.25); }
    .hero-animated__cube-face--back   { transform: rotateY(180deg) translateZ(120px); }
    .hero-animated__cube-face--right  { transform: rotateY(90deg) translateZ(120px); }
    .hero-animated__cube-face--left   { transform: rotateY(-90deg) translateZ(120px); }
    .hero-animated__cube-face--top    { transform: rotateX(90deg) translateZ(120px); }
    .hero-animated__cube-face--bottom { transform: rotateX(-90deg) translateZ(120px); }

    /* Orbiting rings */
    .hero-animated__ring {
      position: absolute;
      border-radius: 50%;
      border: 1.5px solid rgba(0, 229, 255, 0.12);
      top: 50%;
      left: 50%;
    }

    .hero-animated__ring--1 {
      width: 380px;
      height: 380px;
      animation: ring-spin-1 20s linear infinite;
    }

    .hero-animated__ring--2 {
      width: 340px;
      height: 340px;
      animation: ring-spin-2 16s linear infinite;
      border-color: rgba(255, 107, 107, 0.08);
    }

    .hero-animated__ring--3 {
      width: 420px;
      height: 420px;
      animation: ring-spin-3 24s linear infinite;
      border-style: dashed;
      border-color: rgba(0, 229, 255, 0.06);
    }

    @keyframes ring-spin-1 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(0deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(360deg); }
    }

    @keyframes ring-spin-2 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(60deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(420deg); }
    }

    @keyframes ring-spin-3 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(-30deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(330deg); }
    }

    /* Spark — positioned by JS, hidden by default */
    .hero-animated__spark {
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--brand-cyan);
      box-shadow: 0 0 6px var(--brand-cyan), 0 0 14px rgba(0, 229, 255, 0.3);
      opacity: 0;
      pointer-events: none;
      z-index: 4;
      transition: opacity 0.1s ease;
    }
  }
</style>
