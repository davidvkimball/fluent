---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Heading from "@core-elements/heading/Heading.astro";
import Text from "@core-elements/text/Text.astro";
import SimpleText from "@core-elements/simple-text/SimpleText.astro";
import ButtonGroup from "@wrappers/button-group/ButtonGroup.astro";

const {
  eyebrow = "",
  heading = "",
  subtext = "",
  rotatingWords = [],
  buttonSections = [],
  colorScheme = "inherit",
  backgroundColor,
  paddingVertical = "6xl",
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;

const wordsJson = JSON.stringify(rotatingWords);
---

<CustomSection
  class:list={["hero-animated", className]}
  maxContentWidth="2xl"
  paddingHorizontal="lg"
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor={backgroundColor}
  useDefaultEditableBinding={useDefaultEditableBinding}
  {...htmlAttributes}
>
  <!-- Animated background elements -->
  <div class="hero-animated__bg" aria-hidden="true">
    <div class="hero-animated__orb hero-animated__orb--1"></div>
    <div class="hero-animated__orb hero-animated__orb--2"></div>
    <div class="hero-animated__grid"></div>
    <div class="hero-animated__scanline"></div>
  </div>

  <div class="hero-animated__split">
    <div class="hero-animated__content">
      <SimpleText
        class="eyebrow"
        data-prop="eyebrow"
        text={eyebrow}
        alignX="start"
      />

      <h1 class="hero-animated__heading">
        <span class="hero-animated__heading-text" data-prop="heading">{heading}</span>
        {rotatingWords.length > 0 && (
          <span class="hero-animated__rotating-wrap">
            <span class="hero-animated__rotating" data-words={wordsJson}>
              {rotatingWords[0]}
            </span>
            <span class="hero-animated__cursor"></span>
          </span>
        )}
      </h1>

      <Text
        class="hero-animated__subtext"
        alignX="start"
        data-prop="subtext"
        text={subtext}
      />

      <ButtonGroup
        class="hero-animated__buttons"
        buttonSections={buttonSections}
        direction="row"
        alignX="start"
        data-children-prop="buttonSections"
      />
    </div>

    <!-- 3D Element -->
    <div class="hero-animated__visual" aria-hidden="true">
      <!-- Back ring halves (behind tower) -->
      <div class="hero-animated__ring-layer hero-animated__ring-layer--back">
        <div class="hero-animated__ring hero-animated__ring--1"></div>
        <div class="hero-animated__ring hero-animated__ring--2"></div>
        <div class="hero-animated__ring hero-animated__ring--3"></div>
      </div>
      <!-- 3D Wireframe Tower (canvas-rendered) -->
      <div class="hero-animated__tower-wrap">
        <canvas class="hero-animated__tower-canvas" id="hero-tower-canvas" width="500" height="600"></canvas>
      </div>
      <!-- Front ring halves (in front of tower) -->
      <div class="hero-animated__ring-layer hero-animated__ring-layer--front">
        <div class="hero-animated__ring hero-animated__ring--1"></div>
        <div class="hero-animated__ring hero-animated__ring--2"></div>
        <div class="hero-animated__ring hero-animated__ring--3"></div>
      </div>
      <div class="hero-animated__spark" aria-hidden="true"></div>
    </div>
  </div>
</CustomSection>

<script>
  import { onPageLoad } from "@component-utils/onPageLoad";

  function initHeroAnimated() {
    // Rotating words
    const els = document.querySelectorAll('.hero-animated__rotating');
    els.forEach((el) => {
      const htmlEl = el as HTMLElement;
      if (htmlEl.dataset.initialized) return;
      htmlEl.dataset.initialized = 'true';

      const words: string[] = JSON.parse(htmlEl.dataset.words || '[]');
      if (words.length < 2) return;

      let index = 0;

      setInterval(() => {
        htmlEl.classList.add('hero-animated__rotating--out');

        setTimeout(() => {
          index = (index + 1) % words.length;
          htmlEl.textContent = words[index];
          htmlEl.classList.remove('hero-animated__rotating--out');
          htmlEl.classList.add('hero-animated__rotating--in');

          setTimeout(() => {
            htmlEl.classList.remove('hero-animated__rotating--in');
          }, 400);
        }, 400);
      }, 3000);
    });

    // 3D wireframe tower — canvas rendered
    const canvas = document.getElementById('hero-tower-canvas') as HTMLCanvasElement | null;
    const visual = canvas?.closest('.hero-animated__visual') as HTMLElement | null;
    const spark = visual?.querySelector('.hero-animated__spark') as HTMLElement | null;
    const ctx = canvas?.getContext('2d');
    if (canvas && ctx && !canvas.dataset.init) {
      canvas.dataset.init = 'true';

      // Tower geometry — vertices [x, y, z]
      const S = 1.55; // scale
      const V: number[][] = [];
      const E: number[][] = []; // edges [i, j, opacity, width, r, g, b]

      // Helper: add 4 corners of a square platform at height y, half-width hw
      function addPlatform(y: number, hw: number): number {
        const base = V.length;
        V.push([-hw, y, -hw], [hw, y, -hw], [hw, y, hw], [-hw, y, hw]);
        // horizontal edges
        for (let i = 0; i < 4; i++) E.push([base + i, base + (i + 1) % 4, 0.3, 1, 0, 229, 255]);
        return base;
      }

      // Platforms (bottom to top)
      const p0 = addPlatform(-150 * S, 70 * S); // base
      const p1 = addPlatform(-70 * S, 54 * S);  // tier 1
      const p2 = addPlatform(5 * S, 38 * S);    // tier 2
      const p3 = addPlatform(65 * S, 24 * S);   // tier 3
      const p4 = addPlatform(100 * S, 10 * S);  // antenna base

      // Vertical pillars between tiers
      function addPillars(a: number, b: number, opacity: number) {
        for (let i = 0; i < 4; i++) E.push([a + i, b + i, opacity, 1.2, 0, 229, 255]);
      }
      addPillars(p0, p1, 0.4);
      addPillars(p1, p2, 0.45);
      addPillars(p2, p3, 0.5);
      addPillars(p3, p4, 0.45);

      // Cross-braces on each face of each tier
      function addCrossBraces(a: number, b: number) {
        // 4 faces: 0-1, 1-2, 2-3, 3-0
        for (let i = 0; i < 4; i++) {
          const j = (i + 1) % 4;
          E.push([a + i, b + j, 0.1, 0.5, 0, 229, 255]);
          E.push([a + j, b + i, 0.1, 0.5, 0, 229, 255]);
        }
      }
      addCrossBraces(p0, p1);
      addCrossBraces(p1, p2);
      addCrossBraces(p2, p3);

      // Mid-tier horizontal rings (extra detail)
      addPlatform(-110 * S, 62 * S);
      addPlatform(-32 * S, 46 * S);
      addPlatform(35 * S, 31 * S);

      // Antenna mast
      const mast0 = V.length; V.push([0, 100 * S, 0]);
      const mast1 = V.length; V.push([0, 150 * S, 0]);
      E.push([mast0, mast1, 0.6, 1.5, 0, 229, 255]);

      // Antenna arms
      const a1l = V.length; V.push([-18 * S, 115 * S, 0]);
      const a1r = V.length; V.push([18 * S, 115 * S, 0]);
      const a1f = V.length; V.push([0, 115 * S, -18 * S]);
      const a1b = V.length; V.push([0, 115 * S, 18 * S]);
      E.push([a1l, a1r, 0.4, 0.8, 0, 229, 255]);
      E.push([a1f, a1b, 0.4, 0.8, 0, 229, 255]);

      const a2l = V.length; V.push([-12 * S, 130 * S, 0]);
      const a2r = V.length; V.push([12 * S, 130 * S, 0]);
      const a2f = V.length; V.push([0, 130 * S, -12 * S]);
      const a2b = V.length; V.push([0, 130 * S, 12 * S]);
      E.push([a2l, a2r, 0.3, 0.6, 0, 229, 255]);
      E.push([a2f, a2b, 0.3, 0.6, 0, 229, 255]);

      // Coral accent struts (antenna supports)
      E.push([p4, mast0, 0.15, 0.5, 255, 107, 107]);
      E.push([p4 + 2, mast0, 0.15, 0.5, 255, 107, 107]);

      // 3D math
      const DEG = Math.PI / 180;
      function rotY(p: number[], a: number): number[] {
        const c = Math.cos(a), s = Math.sin(a);
        return [p[0]*c - p[2]*s, p[1], p[0]*s + p[2]*c];
      }
      function rotX(p: number[], a: number): number[] {
        const c = Math.cos(a), s = Math.sin(a);
        return [p[0], p[1]*c - p[2]*s, p[1]*s + p[2]*c];
      }
      function project(p: number[]): number[] {
        const persp = 900;
        const scale = persp / (persp + p[2]);
        return [p[0] * scale, p[1] * scale, scale];
      }

      let beaconPhase = 0;

      function drawTower(rx: number, ry: number) {
        const w = canvas!.width;
        const h = canvas!.height;
        const cx = w / 2;
        const cy = h / 2 - 10;
        ctx!.clearRect(0, 0, w, h);

        const rxr = rx * DEG;
        const ryr = ry * DEG;

        // Transform all vertices
        const projected = V.map(v => {
          let p = rotY(v, ryr);
          p = rotX(p, rxr);
          return project(p);
        });

        // Sort edges by average depth (back to front)
        const sortedEdges = E.map((e, i) => {
          const z = (projected[e[0]][2] + projected[e[1]][2]) / 2;
          return { idx: i, z };
        }).sort((a, b) => a.z - b.z);

        // Draw edges
        for (const { idx } of sortedEdges) {
          const e = E[idx];
          const a = projected[e[0]];
          const b = projected[e[1]];
          const depthFade = Math.min(a[2], b[2]);
          const opacity = (e[2] as number) * Math.max(0.3, Math.min(1, depthFade * 1.2));
          ctx!.beginPath();
          ctx!.moveTo(cx + a[0], cy - a[1]);
          ctx!.lineTo(cx + b[0], cy - b[1]);
          ctx!.strokeStyle = `rgba(${e[4]},${e[5]},${e[6]},${opacity})`;
          ctx!.lineWidth = e[3] as number;
          ctx!.stroke();
        }

        // Draw vertex dots at platform corners
        for (let i = 0; i <= p4 + 3; i++) {
          const p = projected[i];
          const r = i <= p0 + 3 ? 2 : 1.5;
          ctx!.beginPath();
          ctx!.arc(cx + p[0], cy - p[1], r * p[2], 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(0,229,255,${0.3 * p[2]})`;
          ctx!.fill();
        }

        // Beacon at antenna tip
        beaconPhase += 0.03;
        const bp = projected[mast1];
        const beaconAlpha = 0.4 + 0.5 * Math.sin(beaconPhase);
        // Glow
        ctx!.beginPath();
        ctx!.arc(cx + bp[0], cy - bp[1], 12, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(0,229,255,${beaconAlpha * 0.08})`;
        ctx!.fill();
        // Ring
        const ringSize = 4 + 6 * ((Math.sin(beaconPhase) + 1) / 2);
        const ringAlpha = 0.3 * (1 - (ringSize - 4) / 6);
        ctx!.beginPath();
        ctx!.arc(cx + bp[0], cy - bp[1], ringSize, 0, Math.PI * 2);
        ctx!.strokeStyle = `rgba(0,229,255,${ringAlpha})`;
        ctx!.lineWidth = 0.8;
        ctx!.stroke();
        // Dot
        ctx!.beginPath();
        ctx!.arc(cx + bp[0], cy - bp[1], 3, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(0,229,255,${beaconAlpha})`;
        ctx!.fill();
      }

      // Interaction state
      let baseX = -12;
      let baseY = 20;
      let dragX = 0;
      let dragY = 0;
      let velocityX = 0;
      let velocityY = 0;
      let isDragging = false;
      let startMouseX = 0;
      let startMouseY = 0;
      let startDragX = 0;
      let startDragY = 0;
      let lastMouseX = 0;
      let lastMouseY = 0;
      let lastMoveTime = 0;
      let animating = false;
      let sparkTimeout: number | null = null;
      let rafId = 0;

      function normalizeAngle(a: number): number {
        a = a % 360;
        if (a > 180) a -= 360;
        if (a < -180) a += 360;
        return a;
      }

      function emitSpark(speed: number) {
        if (!spark || !visual) return;
        if (speed < 1.5) return;
        const rect = visual.getBoundingClientRect();
        const cxx = rect.width / 2;
        const cyy = rect.height / 2;
        const angle = Math.random() * Math.PI * 2;
        const dist = 100 + Math.random() * 40;
        spark.style.left = `${cxx + Math.cos(angle) * dist}px`;
        spark.style.top = `${cyy + Math.sin(angle) * dist}px`;
        spark.style.opacity = `${Math.min(speed / 8, 0.8)}`;
        if (sparkTimeout) clearTimeout(sparkTimeout);
        sparkTimeout = window.setTimeout(() => { spark.style.opacity = '0'; }, 80 + Math.random() * 60);
      }

      function update() {
        const scrollY = window.scrollY;
        const rx = baseX + scrollY * 0.03 + dragX;
        const ry = baseY + scrollY * 0.05 + dragY;
        drawTower(rx, ry);
      }

      // Idle animation loop for beacon pulse
      function idleLoop() {
        if (!animating && !isDragging) update();
        rafId = requestAnimationFrame(idleLoop);
      }
      rafId = requestAnimationFrame(idleLoop);

      function animateMomentum() {
        if (isDragging) { animating = false; return; }
        const speed = Math.sqrt(velocityX * velocityX + velocityY * velocityY);
        if (speed < 0.05) { animating = false; return; }
        dragX += velocityX;
        dragY += velocityY;
        dragX = normalizeAngle(dragX);
        dragY = normalizeAngle(dragY);
        velocityX *= 0.95;
        velocityY *= 0.95;
        const maxV = 8;
        velocityX = Math.max(-maxV, Math.min(maxV, velocityX));
        velocityY = Math.max(-maxV, Math.min(maxV, velocityY));
        if (Math.random() < 0.3) emitSpark(speed);
        update();
        requestAnimationFrame(animateMomentum);
      }

      window.addEventListener('scroll', update, { passive: true });

      const target = visual || canvas;
      target.style.cursor = 'grab';

      target.addEventListener('pointerdown', (e: PointerEvent) => {
        isDragging = true;
        velocityX = 0; velocityY = 0;
        startMouseX = e.clientX; startMouseY = e.clientY;
        lastMouseX = e.clientX; lastMouseY = e.clientY;
        lastMoveTime = Date.now();
        startDragX = dragX; startDragY = dragY;
        target.style.cursor = 'grabbing';
        target.setPointerCapture(e.pointerId);
        e.preventDefault();
      });

      window.addEventListener('pointermove', (e: PointerEvent) => {
        if (!isDragging) return;
        dragY = normalizeAngle(startDragY + (e.clientX - startMouseX) * 0.3);
        dragX = normalizeAngle(startDragX - (e.clientY - startMouseY) * 0.3);
        const now = Date.now();
        const dt = Math.max(now - lastMoveTime, 1);
        velocityY = (e.clientX - lastMouseX) / dt * 8;
        velocityX = -(e.clientY - lastMouseY) / dt * 8;
        const maxV = 8;
        velocityX = Math.max(-maxV, Math.min(maxV, velocityX));
        velocityY = Math.max(-maxV, Math.min(maxV, velocityY));
        if (Math.random() < 0.4) emitSpark(Math.sqrt(velocityX*velocityX+velocityY*velocityY));
        lastMouseX = e.clientX; lastMouseY = e.clientY; lastMoveTime = now;
        update();
      });

      window.addEventListener('pointerup', () => {
        if (!isDragging) return;
        isDragging = false;
        target.style.cursor = 'grab';
        if (!animating) { animating = true; requestAnimationFrame(animateMomentum); }
      });

      update();
    }
  }

  onPageLoad(initHeroAnimated);
</script>

<style>
  @layer page-sections {
    :global(.hero-animated) {
      position: relative;
      overflow: hidden;
      min-height: 80vh;
      display: flex;
      align-items: center;
    }

    :global(.hero-animated) > :global(.outer-content) {
      position: relative;
      z-index: 2;
      width: 100%;
    }

    /* === BACKGROUND EFFECTS === */
    .hero-animated__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
    }

    .hero-animated__orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.5;
    }

    .hero-animated__orb--1 {
      width: 500px;
      height: 500px;
      background: radial-gradient(circle, rgba(0, 229, 255, 0.2), transparent 70%);
      top: -10%;
      left: -5%;
      animation: orb-float-1 16s ease-in-out infinite;
    }

    .hero-animated__orb--2 {
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(255, 107, 107, 0.15), transparent 70%);
      bottom: -15%;
      right: -5%;
      animation: orb-float-2 20s ease-in-out infinite;
    }

    .hero-animated__grid {
      position: absolute;
      bottom: 0;
      left: -20%;
      right: -20%;
      height: 50%;
      background:
        linear-gradient(rgba(0, 229, 255, 0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0, 229, 255, 0.04) 1px, transparent 1px);
      background-size: 60px 60px;
      transform: perspective(500px) rotateX(60deg);
      transform-origin: center bottom;
      mask-image: linear-gradient(to top, rgba(0,0,0,0.4), transparent 80%);
      -webkit-mask-image: linear-gradient(to top, rgba(0,0,0,0.4), transparent 80%);
    }

    .hero-animated__scanline {
      position: absolute;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent 10%, rgba(0, 229, 255, 0.3) 50%, transparent 90%);
      animation: scanline-sweep 5s linear infinite;
    }

    @keyframes scanline-sweep {
      0% { top: 0; opacity: 0; }
      10% { opacity: 1; }
      90% { opacity: 1; }
      100% { top: 100%; opacity: 0; }
    }

    @keyframes orb-float-1 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(40px, 30px); }
      66% { transform: translate(-20px, -15px); }
    }

    @keyframes orb-float-2 {
      0%, 100% { transform: translate(0, 0); }
      33% { transform: translate(-30px, -25px); }
      66% { transform: translate(25px, 20px); }
    }

    /* === SPLIT LAYOUT === */
    .hero-animated__split {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
      gap: var(--spacing-2xl);
    }

    @media (max-width: 768px) {
      .hero-animated__split {
        grid-template-columns: 1fr;
      }

      .hero-animated__visual {
        display: none;
      }
    }

    /* === CONTENT (left) === */
    .hero-animated__content {
      position: relative;
      z-index: 2;
    }

    .hero-animated__heading {
      font-family: var(--font-headings);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      letter-spacing: -0.04em;
      line-height: 1.1;
      color: var(--color-text-strong);
      margin-top: var(--spacing-lg);
      margin-bottom: var(--spacing-lg);
    }

    .hero-animated__heading-text {
      display: block;
    }

    .hero-animated__rotating-wrap {
      display: inline-flex;
      align-items: center;
      gap: 2px;
    }

    .hero-animated__rotating {
      display: inline-block;
      color: var(--brand-cyan);
      transition: opacity 0.4s ease, transform 0.4s ease;
      min-width: 3ch;
    }

    .hero-animated__rotating--out {
      opacity: 0;
      transform: translateY(-12px);
    }

    .hero-animated__rotating--in {
      animation: word-in 0.4s ease forwards;
    }

    @keyframes word-in {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .hero-animated__cursor {
      display: inline-block;
      width: 3px;
      height: 1em;
      background: var(--brand-cyan);
      margin-left: 2px;
      animation: blink 1s steps(1) infinite;
      vertical-align: text-bottom;
    }

    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }

    :global(.hero-animated__subtext) {
      max-width: 480px;
      font-size: var(--font-size-lg);
    }

    :global(.hero-animated__buttons) {
      margin-top: var(--spacing-xl);
    }

    /* === 3D VISUAL (right) === */
    .hero-animated__visual {
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      height: 600px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Ring layers — split for depth illusion */
    .hero-animated__ring-layer {
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    .hero-animated__ring-layer--back {
      z-index: 1;
      clip-path: polygon(0 0, 100% 0, 100% 50%, 0 50%);
    }

    .hero-animated__ring-layer--front {
      z-index: 3;
      clip-path: polygon(0 50%, 100% 50%, 100% 100%, 0 100%);
    }

    /* Tower wrapper */
    .hero-animated__tower-wrap {
      position: relative;
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-animated__tower-canvas {
      display: block;
    }

    /* Orbiting rings */
    .hero-animated__ring {
      position: absolute;
      border-radius: 50%;
      border: 1.5px solid rgba(0, 229, 255, 0.3);
      top: 50%;
      left: 50%;
    }

    .hero-animated__ring--1 {
      width: 440px;
      height: 440px;
      animation: ring-spin-1 20s linear infinite;
      border-width: 2px;
    }

    .hero-animated__ring--2 {
      width: 390px;
      height: 390px;
      animation: ring-spin-2 16s linear infinite;
      border-color: rgba(255, 107, 107, 0.2);
      border-width: 1.5px;
    }

    .hero-animated__ring--3 {
      width: 500px;
      height: 500px;
      animation: ring-spin-3 24s linear infinite;
      border-style: dashed;
      border-color: rgba(0, 229, 255, 0.15);
    }

    @keyframes ring-spin-1 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(0deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(360deg); }
    }

    @keyframes ring-spin-2 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(60deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(420deg); }
    }

    @keyframes ring-spin-3 {
      from { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(-30deg); }
      to   { transform: translate(-50%, -50%) rotateX(70deg) rotateZ(330deg); }
    }

    /* Spark — positioned by JS, hidden by default */
    .hero-animated__spark {
      position: absolute;
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--brand-cyan);
      box-shadow: 0 0 6px var(--brand-cyan), 0 0 14px rgba(0, 229, 255, 0.3);
      opacity: 0;
      pointer-events: none;
      z-index: 4;
      transition: opacity 0.1s ease;
    }
  }
</style>
